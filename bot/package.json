{
  "name": "viva-social-organizer-bot",
  "version": "0.1.0",
  "description": "Laptop-hosted brain for the VivaTech bot. Polls Firestore botInbox, processes via Anthropic Claude, writes replies to whatsappOutbox.",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "private": true
}
