# Copy to .env (gitignored). For production, use Firebase Functions Secrets Manager.
# Generate values from the respective dashboards — see README.md "Day 1 setup checklist".

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Whapi.cloud (WhatsApp)
WHAPI_TOKEN=
WHAPI_WEBHOOK_SECRET=
WHATSAPP_GROUP_ID=
WHATSAPP_GROUP_INVITE=https://chat.whatsapp.com/...

# LinkedIn OIDC (used in Firebase Identity Platform custom provider config,
# not directly by code — listed here as documentation)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Firebase (set automatically by Firebase Admin SDK in Cloud Functions;
# only needed locally for the laptop bot brain)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=

# Bot operational
BOT_HOST_ID=franek-laptop
POLL_INTERVAL_MS=2000
QUIET_HOURS_START=22
QUIET_HOURS_END=8
PARIS_TZ=Europe/Paris

# Admin bootstrap (one-shot grant-admin.ts script reads this)
ADMIN_BOOTSTRAP_EMAIL=franek.jablonski@bel.money
