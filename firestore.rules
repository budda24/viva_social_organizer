rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // PROTOTYPE: any signed-in user can read the public collections (users
    // directory + events + RSVPs + their own buddy matches). The original
    // status=='approved' gate was blocking testers whose user doc still had
    // status='signed_in' from a pre-auto-approve sign-in. Writes stay
    // server-only (Cloud Functions + bot use admin SDK which bypasses
    // rules). Tighten back to isApproved() once invite/approval flow is live.

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if false;

      // Phone, dietary, notLookingFor — owner + admin only.
      match /private/{doc} {
        allow read, write: if isMe(uid) || isAdmin();
      }
    }

    // Invite codes — Functions only.
    match /inviteCodes/{code} {
      allow read, write: if false;
    }

    // Events — public read so the pre-auth /in landing can show a blurred
    // teaser of real events being created. Drives conversion. Writes still
    // go through the bot's admin SDK. RSVPs stay sign-in-gated since they
    // expose participant identity.
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;

      match /rsvps/{uid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // Profile interviews — owner + admin only.
    match /profileInterviews/{sid} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    // Buddy matches — each party can read their own matches.
    match /buddyMatches/{mid} {
      allow read: if isAdmin() || (isSignedIn() &&
        (request.auth.uid == resource.data.uidA ||
         request.auth.uid == resource.data.uidB));
      allow write: if false;
    }

    // Intro requests — double-opt-in connection requests. Either party can
    // read their own; all writes go through the bot (admin SDK).
    match /introRequests/{rid} {
      allow read: if isAdmin() || (isSignedIn() &&
        (request.auth.uid == resource.data.fromUid ||
         request.auth.uid == resource.data.toUid));
      allow write: if false;
    }

    // Bot inbox + conversation state + outbox + log — server-only.
    match /botInbox/{id} { allow read: if isAdmin(); allow write: if false; }
    match /conversationStates/{id} { allow read: if isAdmin(); allow write: if false; }
    match /whatsappOutbox/{id} { allow read: if isAdmin(); allow write: if false; }
    match /whatsappLog/{id} { allow read: if isAdmin(); allow write: if false; }

    // Admin audit + system config.
    match /admin/{doc=**} { allow read, write: if isAdmin(); }
    match /system/{doc=**} { allow read: if isAdmin(); allow write: if false; }
  }
}
